#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PORT="${AI_TOOL_LAUNCHER_PORT:-47623}"
HOST="127.0.0.1"
URL="http://${HOST}:${PORT}"
BROWSER="${AI_TOOL_LAUNCHER_BROWSER:-auto}"

usage() {
  cat <<'USAGE'
AI Tool Launcher

Usage:
  ai-tool-launcher [--browser auto|brave|chrome|chromium|edge|firefox|safari|default]

Environment:
  AI_TOOL_LAUNCHER_PORT       Port for the local launcher server.
  AI_TOOL_LAUNCHER_BROWSER    Browser choice. Same values as --browser.
  NODE                        Node.js executable override.
USAGE
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --browser)
      if [ "$#" -lt 2 ]; then
        echo "Missing value for --browser" >&2
        exit 2
      fi
      BROWSER="$2"
      shift 2
      ;;
    --browser=*)
      BROWSER="${1#--browser=}"
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

BROWSER="$(printf '%s' "${BROWSER}" | tr '[:upper:]' '[:lower:]')"
case "${BROWSER}" in
  auto|brave|chrome|google-chrome|chromium|edge|microsoft-edge|msedge|firefox|safari|default|system)
    ;;
  *)
    echo "Unsupported browser '${BROWSER}'. Use --help for supported browser names." >&2
    exit 2
    ;;
esac

if [ -n "${XDG_STATE_HOME:-}" ]; then
  LOG_DIR="${XDG_STATE_HOME}/ai-tool-launcher"
else
  LOG_DIR="${HOME}/.local/state/ai-tool-launcher"
fi

NODE_BIN="${NODE:-}"
if [ -z "${NODE_BIN}" ]; then
  NODE_BIN="$(command -v node)"
fi

mkdir -p "${LOG_DIR}"

if ! curl -fsS "${URL}/api/health" >/dev/null 2>&1; then
  nohup env AI_TOOL_LAUNCHER_PORT="${PORT}" "${NODE_BIN}" "${APP_DIR}/server.js" >>"${LOG_DIR}/server.log" 2>&1 &
  for _ in {1..40}; do
    if curl -fsS "${URL}/api/health" >/dev/null 2>&1; then
      break
    fi
    sleep 0.25
  done
fi

open_brave() {
  command -v brave >/dev/null 2>&1 && exec brave --app="${URL}" --class=ai-tool-launcher --name="AI Tool Launcher"
}

open_chrome() {
  command -v google-chrome-stable >/dev/null 2>&1 && exec google-chrome-stable --app="${URL}"
  command -v google-chrome >/dev/null 2>&1 && exec google-chrome --app="${URL}"
}

open_chromium() {
  command -v chromium >/dev/null 2>&1 && exec chromium --app="${URL}"
  command -v chromium-browser >/dev/null 2>&1 && exec chromium-browser --app="${URL}"
}

open_edge() {
  command -v microsoft-edge-stable >/dev/null 2>&1 && exec microsoft-edge-stable --app="${URL}"
  command -v microsoft-edge >/dev/null 2>&1 && exec microsoft-edge --app="${URL}"
  command -v msedge >/dev/null 2>&1 && exec msedge --app="${URL}"
  command -v open >/dev/null 2>&1 && exec open -a "Microsoft Edge" "${URL}"
}

open_firefox() {
  command -v firefox >/dev/null 2>&1 && exec firefox --new-window "${URL}"
  command -v firefox-esr >/dev/null 2>&1 && exec firefox-esr --new-window "${URL}"
  command -v open >/dev/null 2>&1 && exec open -a "Firefox" "${URL}"
}

open_safari() {
  command -v open >/dev/null 2>&1 && exec open -a "Safari" "${URL}"
}

open_default() {
  command -v open >/dev/null 2>&1 && exec open "${URL}"
  command -v xdg-open >/dev/null 2>&1 && exec xdg-open "${URL}"
}

case "${BROWSER}" in
  auto)
    open_brave
    open_chrome
    open_chromium
    open_edge
    open_firefox
    open_default
    ;;
  brave)
    open_brave
    ;;
  chrome|google-chrome)
    open_chrome
    ;;
  chromium)
    open_chromium
    ;;
  edge|microsoft-edge|msedge)
    open_edge
    ;;
  firefox)
    open_firefox
    ;;
  safari)
    open_safari
    ;;
  default|system)
    open_default
    ;;
esac

echo "No supported browser opener found for '${BROWSER}'." >&2
echo "Open ${URL} manually in Safari, Edge, Firefox, or another browser." >&2
exit 1
